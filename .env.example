# Database
DATABASE_URL="file:./dev.db"

# AI provider
# Free/local-first options:
# - ollama: fully local, no API cost
# - gemini: can use Google's free tier when you provide GEMINI_API_KEY
# - auto: tries configured online providers first, then Ollama
AI_PROVIDER="ollama"
AI_EXTERNAL_CALLS_DISABLED="false"
AI_RATE_LIMIT_PER_MINUTE="12"
AI_MAX_PROMPT_CHARS="12000"
AI_REQUEST_TIMEOUT_MS="30000"
API_RATE_LIMIT_PER_MINUTE="60"
API_MAX_BODY_BYTES="64000"
WRITE_RATE_LIMIT_PER_MINUTE="30"

# Ollama local inference
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:1b"

# Gemini free-tier capable online mode
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# OpenAI is supported but not free; leave empty unless you explicitly want to use it.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Local export storage
# Leave empty to save PDFs under public/exports.
# Set an absolute path to store generated PDFs elsewhere on your system.
LOCAL_EXPORT_DIR=""

# Local secret required by libraries that expect one.
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Optional deployment gate.
# Set both values before deploying publicly to protect all pages and API routes with browser Basic Auth.
APP_BASIC_AUTH_USER=""
APP_BASIC_AUTH_PASSWORD=""

# Google Drive upload
# Create an OAuth client in Google Cloud and add http://localhost:3000 as an authorized JavaScript origin for local dev.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
